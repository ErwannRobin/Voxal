{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Voxal",
  "version": "0.9.5",
  "identifier": "com.erwann.push2talk.mac",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Voxal",
        "width": 350,
        "height": 680,
        "minWidth": 280,
        "minHeight": 480,
        "resizable": true,
        "center": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "infoPlist": "Info.plist"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["voxal"]
      }
    },
    "updater": {
      "endpoints": ["https://github.com/ErwannRobin/Voxal/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFGN0MyN0IyMTcxNjc4QzQKUldURWVCWVhzaWQ4citZT1JjTTR2ZlVFUElFQ0ZFQklwWFdDcUxSKzlnV29oaWx2eXhqL05DWHcK"
    }
  }
}
