{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Push2Talk",
  "version": "0.1.0",
  "identifier": "com.erwannrobin.push2talk",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Push2Talk",
        "width": 340,
        "height": 520,
        "minWidth": 280,
        "minHeight": 380,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
